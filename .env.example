# 环境变量配置
# 复制这份文件为 .env，填入真实值

# 数据库 (Supabase)
DATABASE_URL=postgresql+asyncpg://postgres.[project_id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://[project_id].supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Claude API ( Anthropic )
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT 密钥 (随机生成，不要泄露)
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200  # 30天

# 邮件发送 (可选，用Mailgun或SMTP)
MAILGUN_API_KEY=your_mailgun_api_key
MAIL_FROM=noreply@chui-chui-xia.com

# 微信公众号 (可选，用于模板消息推送)
WECHAT_APP_ID=wx1234567890abcdef
WECHAT_APP_SECRET=your_wechat_app_secret
WECHAT_TEMPLATE_ID=your_template_id

# Sentry 错误监控 (可选)
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# 环境: development / production
ENV=development
